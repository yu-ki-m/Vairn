{
  "name": "vairn-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build-app.mjs personal",
    "build:team": "node scripts/build-app.mjs team",
    "start:personal": "node scripts/start-personal.mjs",
    "start:team": "node scripts/start-team.mjs",
    "server:test": "vitest run --config server/vitest.config.ts",
    "test": "vitest run --mode test --pool forks",
    "test:watch": "vitest --mode test",
    "test:e2e": "playwright test",
    "test:e2e:backend": "playwright test --config playwright.backend.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@asciidoctor/core": "^3.0.4",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-highlight": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-table": "^3.26.0",
    "@tiptap/extension-task-item": "^3.26.0",
    "@tiptap/extension-task-list": "^3.26.0",
    "@tiptap/extension-underline": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@xyflow/react": "^12.11.0",
    "aws-jwt-verify": "^5.2.1",
    "better-sqlite3": "^12.11.1",
    "buffer": "^6.0.3",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.5",
    "isomorphic-git": "^1.38.4",
    "jspreadsheet-ce": "^5.0.4",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "pg": "^8.22.0",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "javascript-obfuscator": "^5.4.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vitest": "^4.1.8"
  }
}
